{
  "$schema": "https://design-tokens.org/schema.json",
  "primitive": {
    "color": {
      "paper": {
        "50": { "$value": "#FDF9F1", "$type": "color" },
        "100": { "$value": "#F6EEDD", "$type": "color" },
        "200": { "$value": "#EDE0C6", "$type": "color" },
        "300": { "$value": "#E1CFAE", "$type": "color" }
      },
      "terracotta": {
        "300": { "$value": "#E3A184", "$type": "color" },
        "500": { "$value": "#C4694B", "$type": "color" },
        "600": { "$value": "#A8502F", "$type": "color" },
        "700": { "$value": "#833C22", "$type": "color" }
      },
      "sage": {
        "300": { "$value": "#C4D0B4", "$type": "color" },
        "500": { "$value": "#8A9A78", "$type": "color" },
        "600": { "$value": "#6C7C5C", "$type": "color" },
        "700": { "$value": "#535F45", "$type": "color" }
      },
      "brown": {
        "400": { "$value": "#8A7256", "$type": "color" },
        "600": { "$value": "#5C4632", "$type": "color" },
        "800": { "$value": "#3A2C20", "$type": "color" },
        "900": { "$value": "#241A12", "$type": "color" }
      },
      "gold": {
        "400": { "$value": "#D9A441", "$type": "color" },
        "600": { "$value": "#B37F26", "$type": "color" }
      }
    },
    "font": {
      "hand": { "$value": "var(--font-caveat), 'Caveat', cursive", "$type": "fontFamily" },
      "serif": { "$value": "var(--font-lora), 'Lora', Georgia, serif", "$type": "fontFamily" },
      "sans": { "$value": "var(--font-karla), 'Karla', system-ui, sans-serif", "$type": "fontFamily" }
    },
    "motion": {
      "duration": {
        "micro": { "$value": "200ms", "$type": "duration" },
        "base": { "$value": "350ms", "$type": "duration" },
        "reveal": { "$value": "900ms", "$type": "duration" },
        "sway": { "$value": "6s", "$type": "duration" }
      },
      "ease": {
        "organic": { "$value": "cubic-bezier(0.22, 1, 0.36, 1)", "$type": "cubicBezier" },
        "wobble": { "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)", "$type": "cubicBezier" }
      }
    },
    "shape": {
      "blob-1": { "$value": "62% 38% 55% 45% / 45% 55% 45% 55%", "$type": "string" },
      "blob-2": { "$value": "40% 60% 65% 35% / 55% 40% 60% 45%", "$type": "string" },
      "blob-3": { "$value": "55% 45% 40% 60% / 40% 55% 45% 60%", "$type": "string" }
    }
  },
  "semantic": {
    "background": { "$value": "{primitive.color.paper.100}", "$type": "color" },
    "foreground": { "$value": "{primitive.color.brown.800}", "$type": "color" },
    "card": { "$value": "{primitive.color.paper.50}", "$type": "color" },
    "card-foreground": { "$value": "{primitive.color.brown.800}", "$type": "color" },
    "popover": { "$value": "{primitive.color.paper.50}", "$type": "color" },
    "popover-foreground": { "$value": "{primitive.color.brown.800}", "$type": "color" },
    "primary": { "$value": "{primitive.color.terracotta.500}", "$type": "color" },
    "primary-foreground": { "$value": "{primitive.color.paper.50}", "$type": "color" },
    "secondary": { "$value": "{primitive.color.sage.500}", "$type": "color" },
    "secondary-foreground": { "$value": "{primitive.color.paper.50}", "$type": "color" },
    "muted": { "$value": "{primitive.color.paper.200}", "$type": "color" },
    "muted-foreground": { "$value": "{primitive.color.brown.400}", "$type": "color" },
    "accent": { "$value": "{primitive.color.gold.400}", "$type": "color" },
    "accent-foreground": { "$value": "{primitive.color.brown.900}", "$type": "color" },
    "destructive": { "$value": "{primitive.color.terracotta.700}", "$type": "color" },
    "border": { "$value": "{primitive.color.paper.300}", "$type": "color" },
    "input": { "$value": "{primitive.color.paper.300}", "$type": "color" },
    "ring": { "$value": "{primitive.color.terracotta.500}", "$type": "color" },
    "radius": { "$value": "1.5rem", "$type": "dimension" },
    "ink": { "$value": "{primitive.color.brown.900}", "$type": "color" },
    "sage-line": { "$value": "{primitive.color.sage.600}", "$type": "color" },
    "terracotta-deep": { "$value": "{primitive.color.terracotta.700}", "$type": "color" },
    "type-hand": { "$value": "{primitive.font.hand}", "$type": "fontFamily" },
    "type-body": { "$value": "{primitive.font.serif}", "$type": "fontFamily" },
    "type-ui": { "$value": "{primitive.font.sans}", "$type": "fontFamily" },
    "ease-organic": { "$value": "{primitive.motion.ease.organic}", "$type": "cubicBezier" },
    "ease-wobble": { "$value": "{primitive.motion.ease.wobble}", "$type": "cubicBezier" },
    "duration-micro": { "$value": "{primitive.motion.duration.micro}", "$type": "duration" },
    "duration-base": { "$value": "{primitive.motion.duration.base}", "$type": "duration" },
    "duration-reveal": { "$value": "{primitive.motion.duration.reveal}", "$type": "duration" },
    "blob-1": { "$value": "{primitive.shape.blob-1}", "$type": "string" },
    "blob-2": { "$value": "{primitive.shape.blob-2}", "$type": "string" },
    "blob-3": { "$value": "{primitive.shape.blob-3}", "$type": "string" }
  },
  "component": {
    "hero": {
      "title-size": { "$value": "clamp(3.2rem, 9vw, 7.5rem)", "$type": "dimension" },
      "title-leading": { "$value": "0.95", "$type": "number" },
      "note-rotate": { "$value": "-2.5deg", "$type": "string" }
    },
    "button": {
      "primary-bg": { "$value": "{primitive.color.terracotta.500}", "$type": "color" },
      "primary-fg": { "$value": "{primitive.color.paper.50}", "$type": "color" },
      "primary-hover-bg": { "$value": "{primitive.color.terracotta.600}", "$type": "color" },
      "ghost-border": { "$value": "{primitive.color.sage.500}", "$type": "color" },
      "ghost-hover-bg": { "$value": "{primitive.color.sage.300}", "$type": "color" }
    },
    "card": {
      "border": { "$value": "{primitive.color.paper.300}", "$type": "color" },
      "shadow": { "$value": "0 18px 40px -20px rgba(58, 44, 32, 0.35)", "$type": "shadow" }
    }
  }
}
